<!-- LJCConnectionTemplates.xml -->
<members>
  <!-- Constructor Methods -->
  <Constructor>
    <summary>
      Initializes an object instance.
    </summary>
  </Constructor>
  <LoadData>
    <summary>
      Retrieves the connection template data.
    </summary>
		<example>
			<code>
				using LJCDataAccessConfig;

				ConnectionTemplates templates = new ConnectionTemplates();
				templates.LJCLoadData();
			</code>
		</example>
  </LoadData>
  
  <!-- Collection Methods -->
  <Add>
    <summary>
      Creates and adds the object from the provided valus.
    </summary>
    <param name="name">The template configuration name.</param>
    <param name="template">The connection string template.</param>
    <returns></returns>
  </Add>
  <Retrieve>
    <summary>
      Retrieve the data configuration.
    </summary>
    <param name="name">The connection template configuration name.</param>
		<example>
			<code>
				using LJCDataAccessConfig;

				ConnectionTemplates templates = new ConnectionTemplates();
				templates.LJCLoadData();
				ConnectionTemplate template = templates.LJCGetByName("SQLServer");
			</code>
		</example>
  </Retrieve>
  <Save>
    <summary>
      Saves the config data.
    </summary>
  </Save>
  
  <!-- Properties -->
  <TemplateFileSpec>
    <summary>
      The configuration file path.
    </summary>
  </TemplateFileSpec>
</members>
